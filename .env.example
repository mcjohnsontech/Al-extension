# Server environment variables
# Copy this file to .env and fill in your values

# Google Gemini API key — free tier available at:
# https://aistudio.google.com/app/apikey
# NEVER commit the actual key to version control
GEMINI_API_KEY=your-gemini-api-key-here

# Port for the local proxy server
PORT=3000

# Set this to your extension's ID once loaded in Chrome
# Format: chrome-extension://<extension-id>
# Leave as * for local development only
ALLOWED_ORIGIN=*
